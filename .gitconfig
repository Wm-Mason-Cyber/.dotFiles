[core]
    editor = vim

[color]
    ui = auto

# IMPORTANT: replace CHANGE_ME values before making your first commit.
# The install.sh script will prompt you, or run these commands manually:
#   git config --global user.name "Your Name"
#   git config --global user.email "you@school.edu"
[user]
    name  = CHANGE_ME
    email = CHANGE_ME@example.com