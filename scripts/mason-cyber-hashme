#!/usr/bin/env bash
# mason-cyber-hashme - compute common cryptographic hashes for a file or string
#
# Usage:
#   mason-cyber-hashme <file>         hash a file
#   mason-cyber-hashme -s <string>    hash a string (useful for quick comparisons)
#
# Output: MD5, SHA-1, SHA-256, SHA-512

set -euo pipefail

usage() {
    cat <<'EOF'
Usage: mason-cyber-hashme <file>
       mason-cyber-hashme -s <string>

Examples:
  mason-cyber-hashme /etc/hostname
  mason-cyber-hashme -s "hello world"
  mason-cyber-hashme mystery.bin

Output includes MD5, SHA-1, SHA-256, and SHA-512 hashes.
EOF
}

if [ $# -eq 0 ]; then
    usage; exit 1
fi

STRING_MODE=0
if [ "$1" = "-s" ]; then
    STRING_MODE=1
    shift
    if [ $# -eq 0 ]; then
        echo "Error: -s requires a string argument." >&2
        usage; exit 1
    fi
fi

hash_stream() {
    local label="$1"; shift
    local hash
    hash=$("$@") || { echo "  ${label}: (unavailable)"; return; }
    printf '  %-8s %s\n' "${label}:" "$hash"
}

if [ "$STRING_MODE" -eq 1 ]; then
    target="$*"
    printf 'String: "%s"\n\n' "$target"
    hash_stream MD5    sh -c "printf '%s' \"\$1\" | md5sum | awk '{print \$1}'" _ "$target"
    hash_stream SHA-1  sh -c "printf '%s' \"\$1\" | sha1sum | awk '{print \$1}'" _ "$target"
    hash_stream SHA-256 sh -c "printf '%s' \"\$1\" | sha256sum | awk '{print \$1}'" _ "$target"
    hash_stream SHA-512 sh -c "printf '%s' \"\$1\" | sha512sum | awk '{print \$1}'" _ "$target"
else
    target="$1"
    if [ ! -e "$target" ]; then
        echo "Error: '$target' does not exist." >&2
        exit 1
    fi
    if [ ! -f "$target" ]; then
        echo "Error: '$target' is not a regular file." >&2
        exit 1
    fi
    printf 'File: %s  (%d bytes)\n\n' "$target" "$(wc -c < "$target")"
    hash_stream MD5    sh -c "md5sum \"\$1\" | awk '{print \$1}'" _ "$target"
    hash_stream SHA-1  sh -c "sha1sum \"\$1\" | awk '{print \$1}'" _ "$target"
    hash_stream SHA-256 sh -c "sha256sum \"\$1\" | awk '{print \$1}'" _ "$target"
    hash_stream SHA-512 sh -c "sha512sum \"\$1\" | awk '{print \$1}'" _ "$target"
fi

printf '\n'
